# Rob's Gardens - Environment Configuration
#
# This app uses GHL's official widget for chat, voice, and booking.
# The widget is configured via:
# - Widget ID: 69aa7bee4d840e5ae8d1ca7c
# - Location ID: ga76yfab1iQADxaKICLX
# These are embedded in the widget configuration and loaded automatically
# from: https://widgets.leadconnectorhq.com/loader.js

# ---- Admin auth (added in Phase 2 Unit 11) ----

# Google OAuth client ID for the admin sign-in flow.
# Obtain from https://console.cloud.google.com/ → APIs & Services → Credentials
# Exposed to the browser via Vite's VITE_ prefix — safe to expose.
VITE_GOOGLE_CLIENT_ID=

# Comma-separated list of Google account emails allowed to access /admin.
# Example: giles@example.com,info@robgardens.com
ADMIN_EMAILS=

# Base64url-encoded random secret used to sign the admin session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Vercel Blob token for schedule persistence (pre-existing, used by /api/save-schedule).
BLOB_READ_WRITE_TOKEN=
